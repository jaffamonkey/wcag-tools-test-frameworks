200px%3B%20width%3A%20100%25%3B%20height%3A%20100%25%3B%20z-index%3A%202%3B%22%3E%3C%2Fcanvas%3E%3C%2Fdiv%3E%3C%2Ftd%3E%0A%20%20%20%20%3Ctd%3EHigh%20Amplitude%3C%2Ftd%3E%0A%20%20%3C%2Ftr%3E%0A%3C%2Ftbody%3E%3C%2Ftable%3E%0A%0A%3Ch3%3EWhat%20is%20this%3F%3C%2Fh3%3E%0A%0A%3Cp%3E%0A%20%20This%20is%20an%20audio%20generator%20tool%20to%20explore%20the%20timbral%20quality%20of%20the%0A%20%20triangle%20wave%20family%20of%20waveforms%2C%20including%20both%20symmetric%20and%0A%20%20asymmetric%20variants.%20The%20top%20box%20is%20an%20oscilloscope%20view%0A%20%20which%20visualizes%20the%20waveform%2C%20and%20the%20bottom%20box%20is%20a%20harmonic%0A%20%20spectrum%20view.%0A%3C%2Fp%3E%0A%0A%3Cp%3E%0A%20%20Three%20different%20symmetries%20of%20the%20wave%20are%20parameterized%20and%20can%20be%0A%20%20controlled%20to%20%22bias%22%20the%20wave%20away%20from%20symmetrical.%20These%20symmetries%20%2F%0A%20%20biases%20are%3A%0A%0A%20%20%3C%2Fp%3E%3Cul%3E%0A%20%20%20%20%3Cli%3Edownward%E2%80%93upward%20bias%20%E2%80%94%20In%20a%20symmetric%20triangle%20wave%2C%0A%20%20%20%20%20%20there%20is%20equal%20representation%20in%20the%20portions%20of%20the%20waveform%0A%20%20%20%20%20%20which%20have%20an%20upward%20(positive)%20slope%20and%20those%20which%20have%20a%0A%20%20%20%20%20%20downward%20(negative)%20slope.%20A%20negative%20bias%20skews%20representation%0A%20%20%20%20%20%20towards%20the%20downward-sloping%20portion.%20A%20positive%20bias%20on%20this%0A%20%20%20%20%20%20control%20skews%20representation%20towards%20the%20upward-sloping%20portion%0A%20%20%20%20%20%20of%20the%20waveform.%20At%20the%20extremes%20of%20this%20bias%2C%20the%0A%20%20%20%20%20%20waveform%20becomes%20a%20sawtooth%20wave.%0A%20%20%20%20%3C%2Fli%3E%0A%20%20%20%20%3Cli%3Enegative%E2%80%93positive%20bias%20%E2%80%94%20In%20a%20symmetric%20triangle%0A%20%20%20%20%20%20wave%2C%20there%20is%20equal%20representation%20of%20positive%20and%20negative%0A%20%20%20%20%20%20values.%20A%20negative%20bias%20on%20this%20control%20skews%20representation%0A%20%20%20%20%20%20towards%20negative%20values.%20A%20positive%20bias%20on%20this%20control%20skews%0A%20%20%20%20%20%20representation%20towards%20positive%20values.%0A%20%20%20%20%3C%2Fli%3E%0A%20%20%20%20%3Cli%3Ede%C3%A4mping%E2%80%93amping%20bias%20%E2%80%94%20In%20a%20symmetric%20triangle%0A%20%20%20%20%20%20wave%2C%20there%20is%20equal%20representation%20of%20value%20movement%20away%20from%0A%20%20%20%20%20%20zero%20(amping%20up)%20and%20value%20movement%20towards%20zero%20(de%C3%A4mping%0A%20%20%20%20%20%20or%20amping%20down).%20A%20negative%20bias%20on%20this%20control%20skews%0A%20%20%20%20%20%20representation%20towards%20de%C3%A4mping.%20A%20positive%20bias%20on%20this%0A%20%20%20%20%20%20control%20skews%20representation%20towards%20amping%20up.%0A%20%20%20%20%3C%2Fli%3E%0A%20%20%3C%2Ful%3E%0A%3Cp%3E%3C%2Fp%3E%0A%0A%3Cp%3E%0A%20%20In%20addition%2C%20you%20can%20change%20the%20pitch%20(frequency)%20and%20total%20amplitude%20of%0A%20%20the%20note%20being%20played.%20Adjusting%20these%20can%20help%20discern%20the%20various%0A%20%20patterns%20of%20the%20displays.%0A%3C%2Fp%3E%0A%0A%3Cp%3E%0A%20%20%3Ca%20href%3D%22https%3A%2F%2Fgithub.com%2Fdanfuzz%2Fmimu%2Ftree%2Fmain%2Ftriangle-wave-explorer%22%3E%0A%20%20See%20the%20source%3C%2Fa%3E.%0A%3C%2Fp%3E%0A%0A%3Ch3%3EItems%20of%20note%3C%2Fh3%3E%0A%0A%3Cp%3E%0A%20%20At%20many%20frequencies%2C%20you%20can%20observe%20harmonics%20that%20are%20not%20even%0A%20%20multiples%20of%20the%20fundamental%20frequency.%20For%20example%2C%20if%20you%20ramp%20up%0A%20%20the%20pitch%20slowly%2C%20you%20can%20see%20these%20harmonics%20%22bounce%20off%20the%20wall.%22%0A%20%20These%20are%20%3Ci%3Ealiasing%20artifacts%3C%2Fi%3E%20which%20are%20produced%20because%20the%0A%20%20period%20(single%20cycle)%20of%20the%20waveform%20isn't%20a%20whole%20number%20of%20samples.%0A%20%20The%20demo%20code%20reduces%20%E2%80%94%20but%20does%20not%20eliminate%20%E2%80%94%20this%20effect%0A%20%20by%20oversampling%2C%20that%20is%2C%20by%20producing%20samples%20at%20a%20higher%20rate%20than%20the%0A%20%20output%20sample%20rate.%20In%20this%20case%2C%20those%20samples%20are%20simply%20averaged%0A%20%20together%2C%20a%20tactic%20which%20serious%20audio%20engineers%20would%20probably%20scoff%20at%0A%20%20but%20which%20is%20both%20effective%20and%20efficient%20for%20the%20current%20use%20case.%0A%3C%2Fp%3E%0A%0A%3Ctable%20class%3D%22footer%22%3E%0A%20%20%3Ctbody%3E%3Ctr%3E%0A%20%20%20%20%3Ctd%3E%0A%20%20%20%20%20%20Copyright%202015-2025%20the%20Mimu%20Authors%20(Dan%20Bornstein%20et%20alia).%3Cbr%3E%0A%20%20%20%20%20%20SPDX-License-Identifier%3A%20Apache-2.0%0A%20%20%20%20%3C%2Ftd%3E%0A%20%20%20%20%3Ctd%3E%0A%20%20%20%20%20%20%3Ca%20href%3D%22https%3A%2F%2Fmilk.com%2F%22%3Emilk.com%3C%2Fa%3E%20%2F%20%3Ca%20href%3D%22..%2F%22%3Emimu%3C%2Fa%3E%0A%20%20%20%20%3C%2Ftd%3E%0A%20%20%3C%2Ftr%3E%0A%3C%2Ftbody%3E%3C%2Ftable%3E%0A%0A%0A%0A%3C%2Fbody%3E%0A%3C%2Fbody%3E%0A%3C%2Fhtml%3E"
