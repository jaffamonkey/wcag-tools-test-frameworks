ill%20include%20up%20to%20date%20information%0Aof%20exhibits%20outside%20the%20%3Ci%3EEXPO%20%3C%2Fi%3Eterrain.%0A%3C%2Fp%3E%3Cp%3E%0AYou%20might%20read%20a%20%3Ca%20href%3D%22http%3A%2F%2Fwww.ibiblio.org%2Fexpo%2Fexpo%2Fabout_expo.html%22%3Eshort%20note%3C%2Fa%3E%20about%20the%20philosophy%20behind%20%3Ci%3EEXPO%20%3C%2Fi%3E%20to%20get%20you%0Ainspired%20to%20use%20this%20bulletin%20board.%0A%3C%2Fp%3E%3Cp%3E%0A%3Ci%3EMake%20this%20bulletin%20board%20an%20interesting%20board%2C%20and%20%3Cb%3Edo%3C%2Fb%3E%20leave%20your%20own%0Acomments%20about%20the%20exhibit%20here.%20As%20we%20from%20EXPO%20cannot%20keep%20an%20eye%20on%0Aevery%20annotation%20hidden%20behind%20other%20annotations%2C%20we%20prefer%20if%20you%0Awould%20keep%20the%20annotations%20directly%20on%20this%20page.%3C%2Fi%3E%3C%2Fp%3E%3Cp%3E%0A%0A%3Cimg%3E%0A%3C%2Fp%3E%3C%2Fbody%3E%0A%3C%2Fbody%3E%0A%3C%2Fhtml%3E"
