        "URL": "data:text/html;charset=utf-8,%3C!doctype%20html%3E%0A%3Chtml%20lang%3D%22%22%3E%0A%3Chead%3E%0A%20%20%3Cmeta%20charset%3D%22utf-8%22%3E%0A%20%20%3Ctitle%3EThe%20Fuzzboy%20Page%3C%2Ftitle%3E%0A%3C%2Fhead%3E%0A%3Cbody%3E%0A%3Cbody%3E%0A%3Ch1%20align%3D%22center%22%3E%3Cimg%20alt%3D%22Fuzzboy%22%3E%3C%2Fh1%3E%0A%0A%3Cp%3EFuzzboy%20is%20the%20experimental%20%2F%20ambient%20%2F%20industrial%20musical%20group%20that%0Aconsists%20of%20%3Ca%20href%3D%22%2Fhome%2Fdanfuzz%2F%22%3EDanfuzz%3C%2Fa%3E%20and%20his%20equipment.%20The%0Agroup%20has%20been%20producing%20music%20%E2%80%94%20albeit%20sporadically%20%E2%80%94%20since%0A1988.%3C%2Fp%3E%0A%0A%3Cul%3E%0A%3Cli%3E%3Ca%20href%3D%22https%3A%2F%2Ffuzzboy.bandcamp.com%2F%22%3EFuzzboy%20page%20on%20Bandcamp%3C%2Fa%3E%0A%3C%2Fli%3E%3C%2Ful%3E%0A%0A%3Ctable%20cellspacing%3D%2224px%22%3E%0A%3Ctbody%3E%3Ctr%3E%0A%20%20%3Ctd%3E%0A%20%20%20%20%20%3Ca%20href%3D%22https%3A%2F%2Ffuzzboy.bandcamp.com%2Falbum%2Fstaying-up-late-to-make-music-to-fall-asleep-to%22%3E%0A%20%20%20%20%20%20%20%3Cp%3E%3Cimg%3E%3C%2Fp%3E%0A%20%20%20%20%20%20%20%3Cp%3EFind%20it%20on%20Bandcamp.%3C%2Fp%3E%0A%20%20%3C%2Fa%3E%3C%2Ftd%3E%0A%20%20%3Ctd%3E%0A%20%20%3Cp%3EIn%20July%20of%202019%2C%20%3Ci%3ESolipsists%20Unite!%3C%2Fi%3E%20released%20the%0A%20%20new%20album%20%3Ci%3EStaying%20Up%20Late%20To%20Make%20Music%20To%20Fall%20Asleep%20To%3C%2Fi%3E.%20This%20is%20the%0A%20%20the%20second%20full-length%20Fuzzboy%20album.%3C%2Fp%3E%0A%0A%20%20%3Cp%3ETrue%20to%20its%20name%2C%20the%20album%20was%20mostly%20created%20in%20the%20wee%20hours.%20Drawing%0A%20%20inspiration%20from%20several%20electronic%20musicians%20for%20the%20initial%20thrust%20of%20the%0A%20%20pieces%2C%20the%20ultimate%20result%20%E2%80%94%20he%20hopes%20%E2%80%94%20is%20a%20sound%20that%20is%0A%20%20uniquely%20his%20own.%3C%2Fp%3E%0A%0A%20%20%3Cp%3EAll%20tracks%20were%20created%20in%20Caustic%203%20on%20an%20Android%20phone%2C%20with%20final%0A%20%20mastering%20done%20in%20Audacity.%20Field%20recordings%20for%20the%20%22Nakajima%20Design%22%20tracks%0A%20%20were%20made%20using%20a%20Marantz%20PMD620%20(I)%20and%20an%20Android%20phone%20(II%20and%20III)%2C%20using%0A%20%20the%20internal%20microphone%20in%20all%20cases.%3C%2Fp%3E%0A%20%20%3C%2Ftd%3E%0A%3C%2Ftr%3E%0A%3Ctr%3E%0A%20%20%3Ctd%3E%0A%20%20%20%20%20%3Ca%20href%3D%22https%3A%2F%2Ffuzzboy.bandcamp.com%2Falbum%2Fmanipulated-field-recordings-with-lil-marshall%22%3E%0A%20%20%20%20%20%20%20%3Cp%3E%3Cimg%3E%3C%2Fp%3E%0A%20%20%20%20%20%20%20%3Cp%3EFind%20it%20on%20Bandcamp.%3C%2Fp%3E%0A%20%20%3C%2Fa%3E%3C%2Ftd%3E%0A%20%20%3Ctd%3E%0A%20%20%20%20%3Cp%3EIn%20March%20of%202007%2C%20%3Ci%3ESolipsists%20Unite!%3C%2Fi%3E%20released%0A%20%20%20%20%3Ci%3EManipulated%20Field%20Recordings%20with%20Li%E2%80%99l%0A%20%20%20%20Marshall%3C%2Fi%3E.%20This%20was%20the%20first%20Fuzzboy%20release%20in%20over%20a%20decade%2C%0A%20%20%20%20and%20the%20first%20full-length%20Fuzzboy%20album%20ever.%3C%2Fp%3E%0A%0A%20%20%20%20%3Cp%3E%3Ci%3EManipulated%20Field%20Recordings%3C%2Fi%3E%2C%20solidly%20rooted%20in%20the%20tradition%20of%0A%20%20%20%20musique%20concr%C3%A8te%2C%20is%20a%20set%20of%20recordings%20of%20a%20synthesizer%20toy%20in%20its%0A%20%20%20%20native%20habitat%2C%20turned%20introspective%20and%20occasionally%20spooky%0A%20%20%20%20through%20computer%20processing.%20Each%20CD%20package%20is%20hand-made%20and%20uniquely%0A%20%20%20%20numbered.%20(45%20instances%20were%20produced%3A%20a%20prototype%20run%20of%2015%0A%20%20%20%20and%20a%20production%20CD-R%20run%20of%2030.)%3C%2Fp%3E%0A%0A%20%20%20%20%3Cp%3EThe%20album%20celebrates%20the%20addition%20of%20a%0A%20%20%20%20%3Ca%20href%3D%22https%3A%2F%2Fwww.bleeplabs.com%2F%22%3EThingamagoop%3C%2Fa%3E%20to%20the%20Fuzzboy%0A%20%20%20%20equipment%20lineup%2C%20and%20it%20consists%20of%20three%20lengthy%20pieces%20(two%0A%20%20%20%20clock%20in%20at%20about%20twenty%20minutes%20apiece%2C%20and%20the%20other%20at%20about%20ten)%0A%20%20%20%20that%20cover%20a%20range%20of%20territory%3A%20The%20first%20has%20the%20feel%20of%20a%20guided%0A%20%20%20%20tour%20through%20a%20bizarre%20factory.%20The%20second%20is%20reminiscent%20of%20a%20jaunt%0A%20%20%20%20through%20a%20field%20of%20mechanical%20crickets.%20The%20third%20has%20a%20lonely%0A%20%20%20%20city%20feel%20to%20it%2C%20with%20ominous%20overtones.%3C%2Fp%3E%0A%0A%20%20%20%20%3Cp%3EThe%20unifying%20aspect%20of%20the%20work%20as%20a%20whole%20is%20that%20the%20songs%0A%20%20%20%20were%20all%20produced%20in%20the%20same%20manner%3A%20Li%E2%80%99l%20Marshall%20the%0A%20%20%20%20Thingamagoop%20was%20set%20up%20out%20in%20the%20open%20in%20various%20positions%20%2F%0A%20%20%20%20environments%20(never%20in%20a%20studio)%20and%20recorded%20live%20for%20several%0A%20%20%20%20minutes%20at%20a%20time.%20The%20recordings%20for%20a%20particular%20piece%20were%0A%20%20%20%20made%20on%20a%20single%20day%20(for%20which%20the%20piece%20is%20named).%20Then%2C%20over%0A%20%20%20%20the%20course%20of%20several%20days%2C%20the%20various%20recordings%20were%20filtered%2C%0A%20%20%20%20manipulated%2C%20and%20mixed%2C%20only%20rarely%20being%20looped%20or%20repeated.%20The%0A%20%20%20%20three%20acceptable%20results%20of%20this%20process%20were%20included%20in%20the%0A%20%20%20%20album.%3C%2Fp%3E%0A%0A%20%20%20%20%3Cp%3EIt%20might%20be%20classified%20as%20merely%20%E2%80%9Cmusique%20concr%C3%A8te%2C%E2%80%9D%0A%20%20%20%20%E2%80%9Cambient%20experimental%2C%E2%80%9D%20or%20%E2%80%9Ctraditional%20industrial%0A%20%20%20%20noise%2C%E2%80%9D%20but%20however%20you%20want%20to%20file%20it%2C%20the%20album%20is%20proof%0A%20%20%20%20that%20neither%20strong%20tonality%20nor%20a%20ubiquitous%20beat%20are%20required%20for%0A%20%20%20%20music%20to%20move%20one%E2%80%99s%20soul.%3C%2Fp%3E%0A%20%20%3C%2Ftd%3E%0A%3C%2Ftr%3E%0A%3C%2Ftbody%3E%3C%2Ftable%3E%0A%0A%3Ch3%3EFuzzboy%E2%80%99s%20Influences%20Include%3C%2Fh3%3E%0A%3Cul%3E%0A%3Cli%3EBiosphere%3C%2Fli%3E%0A%3Cli%3ECoil%3C%2Fli%3E%0A%3Cli%3EEinst%C3%BCrzende%20Neubauten%3C%2Fli%3E%0A%3Cli%3EExperimental%20Audio%20Research%3C%2Fli%3E%0A%3Cli%3EFront%20242%3C%2Fli%3E%0A%3Cli%3EBrian%20Eno%3C%2Fli%3E%0A%3Cli%3ETomas%20Jirku%3C%2Fli%3E%0A%3Cli%3ELustmord%3C%2Fli%3E%0A%3Cli%3EMy%20Bloody%20Valentine%3C%2Fli%3E%0A%3Cli%3ERichard%20H.%20Kirk%3C%2Fli%3E%0A%3Cli%3EThomas%20K%C3%B6ner%3C%2Fli%3E%0A%3Cli%3EZoviet%20France%3C%2Fli%3E%0A%3C%2Ful%3E%0A%0A%3Ctable%20class%3D%22footer%22%3E%0A%3Ctbody%3E%3Ctr%3E%0A%20%20%3Ctd%3ESite%20copyright%20%C2%A9%201994%E2%80%932024%20Dan%20Bornstein.%20All%20rights%20reserved.%3C%2Ftd%3E%0A%20%20%3Ctd%3E%3Ca%20href%3D%22%2F%22%3Emilk.com%3C%2Fa%3E%20%2F%20fuzzboy%3C%2Ftd%3E%0A%3C%2Ftr%3E%0A%3C%2Ftbody%3E%3C%2Ftable%3E%0A%0A%0A%0A%3C%2Fbody%3E%0A%3C%2Fbody%3E%0A%3C%2Fhtml%3E"
