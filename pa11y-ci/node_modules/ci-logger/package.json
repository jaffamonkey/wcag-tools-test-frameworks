{
  "name": "ci-logger",
  "version": "8.0.1",
  "description": "Very simple logger for CI environments.",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "hooks:pre-commit": "npm run lint && npm run prettier:check",
    "hooks:pre-push": "npm audit --audit-level=high && npm test",
    "lint": "npm run lint:md && npm run lint:js",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:js": "eslint .",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "rebuild-types": "tsc index.js --declaration --allowJs --emitDeclarationOnly",
    "start": "node index.js",
    "test": "jest --ci",
    "test:mutation": "stryker run",
    "test:no-coverage": "jest --ci --collectCoverage false",
    "test:types": "tsd"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/gitlab-ci-utils/ci-logger.git"
  },
  "keywords": [
    "log",
    "logger",
    "continuous integration"
  ],
  "author": "Aaron Goldenthal <npm@aarongoldenthal.com>",
  "license": "MIT",
  "engines": {
    "node": "^20.9.0 || ^22.11.0 || >=24.0.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lib/"
  ],
  "bugs": {
    "url": "https://gitlab.com/gitlab-ci-utils/ci-logger/issues"
  },
  "homepage": "https://gitlab.com/gitlab-ci-utils/ci-logger",
  "devDependencies": {
    "@aarongoldenthal/eslint-config-standard": "^39.0.2",
    "@stryker-mutator/jest-runner": "^9.1.1",
    "eslint": "^9.35.0",
    "jest": "^30.1.3",
    "jest-junit": "^16.0.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "tsd": "^0.33.0",
    "typescript": "^5.9.2"
  }
}
