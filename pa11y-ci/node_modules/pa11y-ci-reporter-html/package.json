{
  "name": "pa11y-ci-reporter-html",
  "version": "8.1.1",
  "description": "Pa11y-ci reporter that generates HTML reports - summary report and detailed reports for each page",
  "main": "index.js",
  "scripts": {
    "build:report": "pa11y-ci -c ./tests/fixtures/configs/pages.pa11yci.json",
    "build:report-container": "pa11y-ci -c ./tests/fixtures/configs/container-pages.pa11yci.json",
    "hooks:pre-commit": "npm run lint && npm run prettier:check",
    "hooks:pre-push": "npm audit --audit-level=critical && npm test",
    "lint": "npm run lint:css && npm run lint:html && npm run lint:js && npm run lint:md",
    "lint:css": "stylelint **/*.handlebars",
    "lint:html": "htmlhint **/*.handlebars",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#Archive\"",
    "playwright-setup": "playwright install",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "test": "jest --ci",
    "test:no-coverage": "jest --ci --collectCoverage false",
    "test:ui": "playwright test"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/gitlab-ci-utils/pa11y-ci-reporter-html.git"
  },
  "keywords": [
    "pa11y",
    "pa11y-ci",
    "a11y",
    "accessibility",
    "ci",
    "testing"
  ],
  "author": "Aaron Goldenthal <npm@aarongoldenthal.com>",
  "license": "MIT",
  "engines": {
    "node": "^20.9.0 || ^22.11.0 || >=24.0.0"
  },
  "files": [
    "index.js",
    "lib/"
  ],
  "bugs": {
    "url": "https://gitlab.com/gitlab-ci-utils/pa11y-ci-reporter-html/issues"
  },
  "homepage": "https://gitlab.com/gitlab-ci-utils/pa11y-ci-reporter-html",
  "dependencies": {
    "ci-logger": "^8.0.1",
    "handlebars": "^4.7.9",
    "pa11y-reporter-html-plus": "^5.1.1"
  },
  "devDependencies": {
    "@aarongoldenthal/eslint-config-standard": "^45.0.0",
    "@aarongoldenthal/stylelint-config-standard": "^22.0.0",
    "@playwright/test": "1.58.2",
    "eslint": "^10.1.0",
    "htmlhint": "^1.9.2",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "markdownlint-cli2": "^0.22.0",
    "pa11y-ci": "^4.1.0",
    "pa11y-ci-reporter-runner": "^6.0.4",
    "prettier": "^3.8.1",
    "serve-handler": "^6.1.7",
    "stylelint": "^17.6.0"
  }
}
